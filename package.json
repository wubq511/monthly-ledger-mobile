{
  "name": "monthly-ledger-mobile",
  "version": "1.0.8",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest run",
    "build:apk": "npx eas-cli@latest build --platform android --profile preview",
    "android:apk:local": "npx expo prebuild --platform android --no-install && cd android && gradlew.bat clean assembleRelease",
    "build:aab": "npx eas-cli@latest build --platform android --profile production"
  },
  "dependencies": {
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^55.0.16",
    "typescript": "~5.9.2",
    "vitest": "^2.1.9"
  },
  "private": true
}
